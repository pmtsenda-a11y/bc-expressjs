// TODO 1: Adaptar el modelo a tu dominio asignado
//
// 1. Renombra "Resource" con el nombre de tu entidad principal
//    Ejemplos: Book, Medicine, Member, Dish
//
// 2. Reemplaza los campos genéricos por los de tu dominio
//    Ejemplos:
//    - Biblioteca:  title String, author String, isbn String, available Boolean
//    - Farmacia:    name String, stock Int, price Float, expiresAt DateTime?
//    - Gimnasio:    name String, email String, plan String, active Boolean
//
// 3. Actualiza @@map con el nombre de la tabla en snake_case
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TODO: Renombra el modelo y adapta los campos a tu dominio
model Resource {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("resources")
}
