// This is your Prisma schema file.
// Adapt the Item model to your assigned domain.
// Examples: Book, Medicine, Equipment, Dish, Room, Course...

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// TODO: Adapta este modelo al identificador de tu dominio
// Ejemplos: Book, Medicine, Equipment, MenuItem...
model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  stock       Int      @default(0)
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // TODO: Agrega campos específicos de tu dominio aquí
  // Ejemplo Biblioteca: isbn String? @unique; author String; pages Int?
  // Ejemplo Farmacia:   activeIngredient String; prescription Boolean

  @@index([createdAt])
  @@index([category])
}

enum Role {
  USER
  ADMIN
}
