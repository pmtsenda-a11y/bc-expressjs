{
  "name": "proyecto-semana-09-testing",
  "version": "1.0.0",
  "description": "Proyecto integrador — testing de API REST con Jest y Supertest",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/express": "5.0.1",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.9",
    "@types/node": "22.15.3",
    "@types/supertest": "6.0.3",
    "jest": "29.7.0",
    "supertest": "7.1.0",
    "ts-jest": "29.3.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "bcrypt": "5.1.1",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "express-rate-limit": "7.5.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "mongodb-memory-server": "10.1.4",
    "mongoose": "8.14.2",
    "zod": "3.24.2"
  }
}
