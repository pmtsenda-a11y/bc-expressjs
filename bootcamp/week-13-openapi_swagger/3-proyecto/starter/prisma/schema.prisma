// This is your Prisma schema file.
// Adapt the Item model to your assigned domain.
//
// Examples:
//   Biblioteca  → model Book  { id, title, author, isbn, available }
//   Farmacia    → model Medicine { id, name, price, stock, expiresAt }
//   Gimnasio    → model Member  { id, name, email, plan, joinedAt }
//   Restaurante → model Dish   { id, name, category, price, available }

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TODO: Adapta este modelo a tu dominio asignado.
// Cambia "Item" por el nombre de tu recurso principal.
// Agrega los campos que correspondan (máximo 5-6 campos recomendado).
model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float    @default(0)
  stock       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
