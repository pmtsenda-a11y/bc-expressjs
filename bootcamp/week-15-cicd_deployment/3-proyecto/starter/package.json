{
  "name": "proyecto-semana-15",
  "version": "1.0.0",
  "description": "Proyecto semana 15 — CI/CD: API REST con pipeline y deploy",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@prisma/client": "6.7.0",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.3",
    "@types/supertest": "6.0.3",
    "jest": "29.7.0",
    "prisma": "6.7.0",
    "supertest": "7.1.0",
    "ts-jest": "29.3.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
